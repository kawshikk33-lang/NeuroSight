APP_NAME=NeuroSight API
API_V1_PREFIX=/api/v1
SECRET_KEY=change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Use Railway PostgreSQL connection URL in production
DATABASE_URL=sqlite:///./neuro_sight.db

SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_BUCKET=data

MLFLOW_TRACKING_URI=sqlite:///./mlflow.db
MLFLOW_S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# JSON array format is required
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","https://your-vercel-domain.vercel.app"]
